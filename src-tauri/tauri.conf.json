{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IPA 桌面助手",
  "version": "0.1.0",
  "identifier": "dev.ipatool.desk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "IPA 桌面助手",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png"]
  }
}
